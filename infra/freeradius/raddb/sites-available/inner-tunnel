# ─────────────────────────────────────────────────────────────────────
#  inner-tunnel virtual server — runs inside the PEAP TLS tunnel.
#
#  authorize:  calls the platform REST hook to get NT-Password and the
#              VLAN assignment (quarantine for new/pending, normal for
#              approved devices).  HTTP 4xx → reject.
#
#  post-auth:  copies VLAN attrs to the outer reply; notifies the hook
#              on success so it can register new devices and send the
#              Telegram approval request.
# ─────────────────────────────────────────────────────────────────────
server inner-tunnel {

    listen {
        ipaddr = 127.0.0.1
        port   = 18120
        type   = auth
    }

    authorize {
        filter_username
        update control { &Proxy-To-Realm := LOCAL }
        chap
        mschap          # detects MS-CHAP attrs, sets Auth-Type := MS-CHAP
        suffix
        update control { &Tmp-String-0 := "peap" }

        # Platform REST hook: returns NT-Password in control{} and
        # Tunnel-* VLAN attrs in reply{}.  On HTTP 4xx (unknown user or
        # rejected device) the module returns "fail" and we reject below.
        rest
        if (rest != ok && rest != updated) {
            reject
        }

        expiration
        logintime
    }

    authenticate {
        Auth-Type MS-CHAP    { mschap }
        Auth-Type MS-CHAP-V2 { mschap }
        eap
    }

    session { sql }

    post-auth {
        # Propagate the VLAN assignment from inner reply to the outer
        # Access-Accept that the AP will actually read.
        update outer.reply {
            Tunnel-Type             += &reply:Tunnel-Type
            Tunnel-Medium-Type      += &reply:Tunnel-Medium-Type
            Tunnel-Private-Group-ID := &reply:Tunnel-Private-Group-ID
        }

        # Notify hook of successful auth.
        # Hook creates device record on first connect and fires Telegram.
        rest
        sql

        Post-Auth-Type REJECT {
            attr_filter.access_reject
            update outer.session-state {
                &Module-Failure-Message := &request:Module-Failure-Message
            }
            sql     # log rejected auths to radpostauth; no Telegram spam
        }
    }

    pre-proxy  { }
    post-proxy { eap }
}
