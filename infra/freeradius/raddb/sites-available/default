#
# Default virtual server for outer EAP, accounting, and post-auth hooks.
# This stays intentionally close to the upstream FreeRADIUS layout so the
# parser behavior is predictable while the app-specific logic lives in the
# SQL and REST modules plus inner-tunnel.
#
server default {

    listen {
        type = auth
        ipaddr = *
        port = 0
        limit {
            max_connections = 16
            lifetime = 0
            idle_timeout = 30
        }
    }

    listen {
        type = acct
        ipaddr = *
        port = 0
    }

    listen {
        type = auth
        ipaddr = *
        port = 0
        proto = tcp
        limit {
            max_connections = 16
            lifetime = 0
            idle_timeout = 30
        }
    }

    authorize {
        filter_username
        preprocess
        suffix

        eap {
            ok = return
        }

        sql
        expiration
        logintime
        pap
    }

    authenticate {
        Auth-Type PAP {
            pap
        }

        Auth-Type CHAP {
            chap
        }

        Auth-Type MS-CHAP {
            mschap
        }

        mschap
        eap
    }

    preacct {
        preprocess
        acct_unique
        suffix
    }

    accounting {
        detail
        sql
        exec
        attr_filter.accounting_response
    }

    session {
        sql
    }

    post-auth {
        update {
            &reply: += &session-state:
        }

        sql
        exec

        Post-Auth-Type REJECT {
            attr_filter.access_reject
            eap
            sql
        }
    }

    pre-proxy {
    }

    post-proxy {
        eap
    }
}
