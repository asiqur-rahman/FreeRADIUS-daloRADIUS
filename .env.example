# ──────────────────────────────────────────────────────────────────────
#  Enterprise WiFi RADIUS Management Platform — Environment
# ──────────────────────────────────────────────────────────────────────
#  Copy this file to .env and adjust values before starting the stack.
#  NEVER commit a real .env. Secrets here are dev-only placeholders.

# ── Postgres ──────────────────────────────────────────────────────────
POSTGRES_USER=radius
POSTGRES_PASSWORD=radius_dev_password_change_me
POSTGRES_DB=radius
POSTGRES_PORT=5432

# Two roles inside the same DB (least-privilege per the architecture doc):
#   app_user      → owns app schema, can write radcheck/radreply/etc. via the RadiusPolicyService
#   radius_user   → used by FreeRADIUS; full access to RADIUS tables, read-only on app users
APP_DB_USER=app_user
APP_DB_PASSWORD=app_user_dev_password
RADIUS_DB_USER=radius_user
RADIUS_DB_PASSWORD=radius_user_dev_password

# ── API ───────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Prisma connection string used by the API (app_user)
DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:5432/radius?schema=public

# JWT — generate a real secret in production (e.g. `openssl rand -base64 64`)
JWT_SECRET=dev_jwt_secret_change_me_in_production_at_least_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Cookie config (refresh tokens live in an HttpOnly cookie)
COOKIE_SECRET=dev_cookie_secret_change_me_at_least_32_characters_long
COOKIE_DOMAIN=
COOKIE_SECURE=false   # set true behind HTTPS

# CORS — comma-separated list of origins the API will accept
CORS_ORIGINS=http://localhost:5173

# Argon2id parameters (per the architecture doc: m=64MiB, t=3, p=4)
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=4
MFA_ENCRYPTION_KEY=dev_mfa_encryption_key_change_before_use_2026
# Turn on after the bootstrap administrator has enrolled MFA.
REQUIRE_ADMIN_MFA=false
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
# Enable in deployments with outbound access to the HIBP k-anonymity API.
HIBP_CHECK_ENABLED=false
HIBP_TIMEOUT_MS=3000

# ── FreeRADIUS ────────────────────────────────────────────────────────
# CoA requests use each active session's configured NAS address, secret, and CoA port.
COA_TIMEOUT_MS=2000
COA_DISCONNECT_ON_PASSWORD_CHANGE=true
COA_DISCONNECT_ON_USER_POLICY_CHANGE=true
COA_DISCONNECT_ON_GROUP_POLICY_CHANGE=false
ALERT_NAS_SILENT_MINUTES=15
ALERT_REJECT_THRESHOLD_5M=20

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── Web ───────────────────────────────────────────────────────────────
# Leave blank in dev — Vite proxies /api/* to the API on the same origin,
# which avoids the cross-port cookie + CORS complexity. Set to a fully
# qualified API URL only for production builds served from a different
# origin than the API.
VITE_API_URL=
