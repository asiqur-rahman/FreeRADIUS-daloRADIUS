# Enterprise WiFi RADIUS Management Platform environment
#
# Copy this file to `.env` and adjust values before starting the stack.
# Never commit a real `.env`. Secrets here are dev-only placeholders.

# Postgres
POSTGRES_USER=radius
POSTGRES_PASSWORD=radius_dev_password_change_me
POSTGRES_DB=radius
POSTGRES_PORT=5433

# Two roles inside the same DB:
#   app_user    -> application schema and RadiusPolicyService writes
#   radius_user -> FreeRADIUS SQL access
APP_DB_USER=app_user
APP_DB_PASSWORD=app_user_dev_password
RADIUS_DB_USER=radius_user
RADIUS_DB_PASSWORD=radius_user_dev_password

# API
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Prisma connection string used by the API (app_user)
DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:5433/radius?schema=public

# JWT and cookies
JWT_SECRET=dev_jwt_secret_change_me_in_production_at_least_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_SECRET=dev_cookie_secret_change_me_at_least_32_characters_long
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Frontend
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=

# Password and MFA policy
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=4
MFA_ENCRYPTION_KEY=dev_mfa_encryption_key_change_before_use_2026
REQUIRE_ADMIN_MFA=false
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
HIBP_CHECK_ENABLED=false
HIBP_TIMEOUT_MS=3000

# Managed client certificate issuance for EAP-TLS. Optional.
DEVICE_CERT_CA_CERT_PATH=
DEVICE_CERT_CA_KEY_PATH=
DEVICE_CERT_CA_CERT_PEM=
DEVICE_CERT_CA_KEY_PEM=
DEVICE_CERT_CA_KEY_PASSPHRASE=
DEVICE_CERT_VALIDITY_DAYS=365
DEVICE_CERT_SUBJECT_ORGANIZATION=RadiusOps
DEVICE_CERT_SUBJECT_ORGANIZATIONAL_UNIT=Managed WiFi
DEVICE_CERT_SUBJECT_COUNTRY=
DEVICE_CERT_SUBJECT_STATE=
DEVICE_CERT_SUBJECT_LOCALITY=

# FreeRADIUS and policy behavior
# HOOK_SECRET in docker-compose must match RADIUS_HOOK_SECRET here.
RADIUS_HOOK_SECRET=dev-hook-secret-change-in-prod
# Set to true to enforce the IP allowlist (admin Settings → RADIUS IP Guard).
# When false, all source IPs may call /api/v1/radius/*.
RADIUS_IP_GUARD_ENABLED=false
QUARANTINE_VLAN_ID=99
NORMAL_VLAN_ID=10
COA_TIMEOUT_MS=2000
COA_DISCONNECT_ON_PASSWORD_CHANGE=true
COA_DISCONNECT_ON_USER_POLICY_CHANGE=true
COA_DISCONNECT_ON_GROUP_POLICY_CHANGE=false
ALERT_NAS_SILENT_MINUTES=15
ALERT_REJECT_THRESHOLD_5M=20

# Telegram bot. Optional if you only want dashboard approvals.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
