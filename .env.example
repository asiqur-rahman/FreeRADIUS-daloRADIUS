# ─────────────────────────────────────────────────────────────────────────────
#  RadiusOps — environment template
#
#  Copy this file to `.env` and adjust the values before starting the stack.
#  Never commit a real .env — the secrets here are dev-only placeholders.
#
#  Fields that are configurable at runtime through the admin UI are NOT listed
#  here (they live in the database).  Configure them after first login:
#    • Telegram bot         → Admin → Settings → Telegram
#    • Certificate issuance → Admin → Settings → Certificate Issuance
#    • FreeRADIUS reload    → Admin → Settings → FreeRADIUS
# ─────────────────────────────────────────────────────────────────────────────

# Docker Compose — loads all three service layers automatically.
# Lets you use just:  docker compose up -d  (no -f flags needed)
COMPOSE_FILE=docker-compose.db.yml:docker-compose.radius.yml:docker-compose.app.yml

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=radius
POSTGRES_PASSWORD=radius_dev_password_change_me
POSTGRES_DB=radius
POSTGRES_PORT=5433

# Prisma / API connection (app_user role)
DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:5433/radius?schema=public

# Two least-privilege DB roles:
#   app_user    — application schema + RadiusPolicyService writes
#   radius_user — FreeRADIUS rlm_sql read-only access
APP_DB_USER=app_user
APP_DB_PASSWORD=app_user_dev_password
RADIUS_DB_USER=radius_user
RADIUS_DB_PASSWORD=radius_user_dev_password

# ── API server ────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Security secrets — CHANGE ALL THREE before going to production ────────────
# JWT_SECRET      : signs access tokens            (min 32 chars)
# COOKIE_SECRET   : signs session cookies          (min 32 chars)
# MFA_ENCRYPTION_KEY : encrypts stored TOTP seeds  (min 32 chars, NEVER rotate)
JWT_SECRET=dev_jwt_secret_change_me_in_production_at_least_32_chars
COOKIE_SECRET=dev_cookie_secret_change_me_at_least_32_characters_long
MFA_ENCRYPTION_KEY=dev_mfa_encryption_key_change_before_use_2026

# ── Token / cookie tuning ─────────────────────────────────────────────────────
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ── Frontend ──────────────────────────────────────────────────────────────────
WEB_PORT=8123
CORS_ORIGINS=http://localhost:5173,http://localhost:8123
# VITE_API_URL: leave empty for same-origin (nginx proxy); set for split deploys
VITE_API_URL=

# ── Password / MFA policy ─────────────────────────────────────────────────────
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=4
REQUIRE_ADMIN_MFA=false
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
HIBP_CHECK_ENABLED=false
HIBP_TIMEOUT_MS=3000

# ── FreeRADIUS ────────────────────────────────────────────────────────────────
# RADIUS_HOOK_SECRET must match HOOK_SECRET in docker-compose.radius.yml.
RADIUS_HOOK_SECRET=dev-hook-secret-change-in-prod

# CN for the auto-generated EAP server certificate.
# Used when certs/ is empty or the existing key is passphrase-encrypted.
# Set to your public hostname in production.
RADIUS_CERT_CN=radius.local

# Allow direct MS-CHAP auth (radtest, supplicants without EAP).
#   true  → useful in development / lab testing
#   false → production default; only PEAP-wrapped auth is accepted
ALLOW_DIRECT_MSCHAP=false

# Reject devices not yet approved by an admin.
#   true  → unapproved devices get Access-Reject            (recommended for production)
#   false → unapproved devices land on the quarantine VLAN  (requires proper VLAN isolation)
DEVICE_APPROVAL_REQUIRED=true

# When true, enforce the IP allowlist (Admin → Settings → RADIUS IP Guard).
RADIUS_IP_GUARD_ENABLED=false

# ── CoA — Change-of-Authorization ────────────────────────────────────────────
COA_TIMEOUT_MS=2000
COA_DISCONNECT_ON_PASSWORD_CHANGE=true
COA_DISCONNECT_ON_USER_POLICY_CHANGE=true
COA_DISCONNECT_ON_GROUP_POLICY_CHANGE=false

# ── Alert thresholds ──────────────────────────────────────────────────────────
ALERT_NAS_SILENT_MINUTES=15
ALERT_REJECT_THRESHOLD_5M=20
