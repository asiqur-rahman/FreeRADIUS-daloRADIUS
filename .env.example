# Enterprise WiFi RADIUS Management Platform environment
#
# Copy this file to `.env` and adjust values before starting the stack.
# Never commit a real `.env`. Secrets here are dev-only placeholders.

# Docker Compose — load all three service layers automatically.
# This means you can use just: docker compose up -d   (no -f flags needed)
COMPOSE_FILE=docker-compose.db.yml:docker-compose.radius.yml:docker-compose.app.yml

# Postgres
POSTGRES_USER=radius
POSTGRES_PASSWORD=radius_dev_password_change_me
POSTGRES_DB=radius
POSTGRES_PORT=5433

# Prisma connection string used by the API (app_user)
DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:5433/radius?schema=public

# Two roles inside the same DB:
#   app_user    -> application schema and RadiusPolicyService writes
#   radius_user -> FreeRADIUS SQL access
APP_DB_USER=app_user
APP_DB_PASSWORD=app_user_dev_password
RADIUS_DB_USER=radius_user
RADIUS_DB_PASSWORD=radius_user_dev_password

# API
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# JWT and cookies
JWT_SECRET=dev_jwt_secret_change_me_in_production_at_least_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_SECRET=dev_cookie_secret_change_me_at_least_32_characters_long
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Frontend
WEB_PORT=8123
CORS_ORIGINS=http://localhost:5173,http://localhost:8123
VITE_API_URL=

# Password and MFA policy
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=4
MFA_ENCRYPTION_KEY=dev_mfa_encryption_key_change_before_use_2026
REQUIRE_ADMIN_MFA=false
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
HIBP_CHECK_ENABLED=false
HIBP_TIMEOUT_MS=3000

# ── Managed client certificate issuance for EAP-TLS ──────────────────
#
# WHEN DO YOU NEED THIS?
#   Only when using EAP-TLS (certificate-based WiFi login).
#   If you are only using PEAP-MSCHAPv2 (username + password), leave
#   every DEVICE_CERT_* variable empty — they are completely ignored.
#
# HOW TO FILL THESE IN:
#   Run:  pnpm lab:device-ca
#   It generates a local CA and automatically writes the PEM content
#   into this file — you do not need to edit anything manually.
#
# WHY INLINE PEM (not file paths)?
#   This file is loaded by the Docker API container.  The container has
#   no access to files on the Windows host, so the certificate content
#   is embedded directly here as text.  File paths live in apps/api/.env
#   (written automatically by the same script, for local pnpm dev use).

# CA certificate and private key — filled in by: pnpm lab:device-ca
DEVICE_CERT_CA_CERT_PEM=
DEVICE_CERT_CA_KEY_PEM=

# Passphrase protecting the CA private key.
# Leave empty if the key was generated without encryption (pnpm lab:device-ca
# creates an unencrypted key, so this is blank for local testing).
DEVICE_CERT_CA_KEY_PASSPHRASE=

# How many days an issued client certificate stays valid.
# Max allowed by browsers and MDM systems is 397 days. 365 is a safe default.
DEVICE_CERT_VALIDITY_DAYS=365

# X.509 subject fields stamped into every issued client certificate.
# These appear in the "Issued By" details on the device's certificate screen.
#   O  = your company or organisation name
#   OU = team or department (e.g. "IT", "Managed WiFi", "Corp Devices")
#   C  = 2-letter ISO country code (US, GB, BD, SG …)
#   ST = full state or province name (optional)
#   L  = city / locality (optional)
DEVICE_CERT_SUBJECT_ORGANIZATION=RadiusOps
DEVICE_CERT_SUBJECT_ORGANIZATIONAL_UNIT=Managed WiFi
DEVICE_CERT_SUBJECT_COUNTRY=
DEVICE_CERT_SUBJECT_STATE=
DEVICE_CERT_SUBJECT_LOCALITY=


# FreeRADIUS and policy behavior
# HOOK_SECRET in docker-compose must match RADIUS_HOOK_SECRET here.
RADIUS_HOOK_SECRET=dev-hook-secret-change-in-prod
# Set to true to enforce the IP allowlist (admin Settings → RADIUS IP Guard).
# When false, all source IPs may call /api/v1/radius/*.
RADIUS_IP_GUARD_ENABLED=false
QUARANTINE_VLAN_ID=99
NORMAL_VLAN_ID=10
COA_TIMEOUT_MS=2000
COA_DISCONNECT_ON_PASSWORD_CHANGE=true
COA_DISCONNECT_ON_USER_POLICY_CHANGE=true
COA_DISCONNECT_ON_GROUP_POLICY_CHANGE=false
ALERT_NAS_SILENT_MINUTES=15
ALERT_REJECT_THRESHOLD_5M=20
# Allow direct MS-CHAP auth (radtest, supplicants without EAP).
# true  → useful in development / lab testing
# false → production default; only PEAP-wrapped auth is accepted
ALLOW_DIRECT_MSCHAP=false
# Reject devices that are not yet approved by an admin.
# true  → unapproved devices get Access-Reject (recommended for production)
# false → unapproved devices land on the quarantine VLAN (requires proper VLAN isolation)
DEVICE_APPROVAL_REQUIRED=true
# CN for the auto-generated EAP server certificate (used when certs/ is empty
# or the existing key is passphrase-encrypted). Set to your public hostname.
RADIUS_CERT_CN=cloud.braintechsolution.com

# Telegram bot. Optional if you only want dashboard approvals.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

