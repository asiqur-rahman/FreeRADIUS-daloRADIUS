{
  "name": "@app/radius",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "In-house RADIUS server. Replaces FreeRADIUS for the Phase 1-3 wire surface (Phase A1).",
  "scripts": {
    "dev": "node --openssl-legacy-provider --env-file=.env --import tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --openssl-legacy-provider --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --openssl-legacy-provider --env-file=test/.env --import tsx --test \"test/**/*.test.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "rig:seed": "node --openssl-legacy-provider --env-file=.env --import tsx scripts/seed-test-rig.ts",
    "rig:test-peap": "node --openssl-legacy-provider --env-file=.env --import tsx scripts/test-peap.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "selfsigned": "^2.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
