{
  "name": "wifi-radius-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise WiFi RADIUS Management Platform",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @app/api run prisma:migrate",
    "db:status": "pnpm --filter @app/api run prisma:status",
    "db:deploy": "pnpm --filter @app/api run prisma:deploy",
    "db:generate": "pnpm --filter @app/api run prisma:generate",
    "db:seed": "pnpm --filter @app/api run seed",
    "lab:check": "powershell -File .\\ops\\check-lab-readiness.ps1",
    "lab:config": "powershell -File .\\ops\\print-lab-config.ps1",
    "lab:device-ca": "powershell -File .\\ops\\generate-dev-device-ca.ps1",
    "lab:client-cert": "powershell -File .\\ops\\generate-test-client-cert.ps1",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:prod:up": "docker compose -f docker-compose.yml -f docker-compose.production.yml up -d --build"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
