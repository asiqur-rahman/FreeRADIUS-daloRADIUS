{
  "name": "radiusnexus",
  "version": "0.1.0",
  "private": true,
  "description": "RadiusNexus — Enterprise Wi-Fi Access Control Platform (PEAP / EAP-TLS, device approval workflow, Telegram notifications)",
  "author": "Md. Asiqur Rahman Khan",
  "maintainers": [
    {
      "name": "Md. Asiqur Rahman Khan"
    }
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @app/api run prisma:migrate",
    "db:status": "pnpm --filter @app/api run prisma:status",
    "db:deploy": "pnpm --filter @app/api run prisma:deploy",
    "db:generate": "pnpm --filter @app/api run prisma:generate",
    "db:seed": "docker exec radius-api node --openssl-legacy-provider prisma/seed.mjs",
    "lab:check": "powershell -File .\\ops\\check-lab-readiness.ps1",
    "lab:config": "powershell -File .\\ops\\print-lab-config.ps1",
    "lab:device-ca": "powershell -File .\\ops\\generate-dev-device-ca.ps1",
    "lab:client-cert": "powershell -File .\\ops\\generate-test-client-cert.ps1",
    "certs:generate": "bash infra/freeradius/generate-certs.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
