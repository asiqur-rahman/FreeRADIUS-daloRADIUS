{
  "name": "wifi-radius-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise WiFi RADIUS Management Platform",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @app/api exec prisma migrate dev",
    "db:deploy": "pnpm --filter @app/api exec prisma migrate deploy",
    "db:generate": "pnpm --filter @app/api exec prisma generate",
    "db:seed": "pnpm --filter @app/api exec tsx prisma/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:prod:up": "docker compose -f docker-compose.yml -f docker-compose.production.yml up -d --build"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
